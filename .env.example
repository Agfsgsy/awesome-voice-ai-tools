# Voice AI Studio Arabic - Environment Variables
# Copy to .env and fill in your values

# App Settings
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=false

# Security: JWT Secret (generate a strong secret: openssl rand -base64 64)
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Admin Account (set for first-run admin access)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# Google Gemini TTS (optional)
GEMINI_API_KEY=
GEMINI_TTS_MODEL=gemini-3.1-flash-tts-preview

# Upload Limits
MAX_UPLOAD_MB=50

# CORS (comma-separated allowed origins, empty = localhost only)
CORS_ORIGINS=

# Rate Limiting
RATE_LIMIT_ENABLED=true

# API Documentation (disable in production)
DOCS_ENABLED=true
